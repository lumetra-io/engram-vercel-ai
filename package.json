{
  "name": "@lumetra/engram-vercel-ai",
  "version": "0.1.1",
  "description": "Vercel AI SDK adapter for Engram — Lumetra's durable memory service. Exposes Engram's six REST endpoints as Vercel AI SDK tools.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "PRIVACY.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vercel",
    "ai-sdk",
    "ai",
    "tools",
    "memory",
    "engram",
    "lumetra",
    "llm",
    "agent"
  ],
  "author": "Lumetra Labs Inc.",
  "license": "MIT",
  "homepage": "https://lumetra.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/lumetra-io/engram-vercel-ai"
  },
  "peerDependencies": {
    "ai": ">=5",
    "zod": "^3.23.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ai": "^6.0.0",
    "typescript": "^5.6.0",
    "zod": "^3.25.76"
  }
}
